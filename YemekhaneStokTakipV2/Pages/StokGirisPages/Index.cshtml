@page
@model YemekhaneStokTakipV2.Pages.StokGirisPages.IndexModel

@{
    ViewData["Title"] = "Stok Girişleri";
}

<h2 class="mb-3">📥 Stok Girişleri</h2>

<p>
    <a asp-page="Create" class="btn btn-success">
        ➕ Yeni Stok Girişi
    </a>
</p>

<table class="table table-bordered table-hover table-striped align-middle">
    <thead class="table-success">
        <tr>
            <th>Ürün</th>
            <th>Tedarikçi</th>
            <th>Miktar</th>
            <th>Tarih</th>
            <th>Açıklama</th>
            <th style="width:250px;">İşlemler</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model.StokGiris)
        {
            <tr>
                <td>@item.Urun?.UrunAdi</td>

                <td>@item.Tedarikci?.FirmaAdi</td>

                <td>
                    @if (item.Miktar <= 20)
                    {
                        <span class="badge bg-danger fs-6">@item.Miktar</span>
                    }
                    else
                    {
                        <span class="badge bg-success fs-6">@item.Miktar</span>
                    }
                </td>

                <td>@item.Tarih.ToString("dd.MM.yyyy HH:mm")</td>

                <td>@item.Aciklama</td>

                <td>
                    <a asp-page="./Edit"
                       asp-route-id="@item.StokGirisId"
                       class="btn btn-warning btn-sm">
                        ✏️ Düzenle
                    </a>

                    <a asp-page="./Details"
                       asp-route-id="@item.StokGirisId"
                       class="btn btn-info btn-sm text-white">
                        👁️ Detay
                    </a>

                    <a asp-page="./Delete"
                       asp-route-id="@item.StokGirisId"
                       class="btn btn-danger btn-sm">
                        🗑️ Sil
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>
@page
@model YemekhaneStokTakipV2.Pages.StokGirisPages.IndexModel

@{
    ViewData["Title"] = "Stok Girişleri";
}

<h1>📥 Stok Girişleri</h1>

<p>
    <a asp-page="Create" class="btn btn-success">➕ Yeni Stok Girişi</a>
</p>

<table class="table table-bordered table-striped">
    <thead class="table-dark">
        <tr>
            <th>Ürün</th>
            <th>Tedarikçi</th>
            <th>Miktar</th>
            <th>Tarih</th>
            <th>Açıklama</th>
            <th>İşlemler</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.StokGiris)
        {
            <tr>
                <td>@item.Urun?.UrunAdi</td>
                <td>@item.Tedarikci?.FirmaAdi</td>
                <td>@item.Miktar</td>
                <td>@item.Tarih.ToString("dd.MM.yyyy HH:mm")</td>
                <td>@item.Aciklama</td>
                <td>
                    <a asp-page="./Edit" asp-route-id="@item.StokGirisId" class="btn btn-warning btn-sm">Düzenle</a>

                    <a asp-page="./Details" asp-route-id="@item.StokGirisId" class="btn btn-info btn-sm">Detay</a>

                    <a asp-page="./Delete" asp-route-id="@item.StokGirisId" class="btn btn-danger btn-sm">Sil</a>
                </td>
            </tr>
        }
    </tbody>
</table>
@page
@model YemekhaneStokTakipV2.Pages.StokGirisPages.IndexModel

@{
    ViewData["Title"] = "Stok Girişleri";
}

<div class="d-flex justify-content-between align-items-center mb-4">

    <div>

        <h2 class="fw-bold">
            Stok Girişleri
        </h2>

        <small class="text-muted">
            Sisteme eklenen stok giriş kayıtları
        </small>

    </div>

    <a asp-page="Create" class="btn btn-success">
        Yeni Stok Girişi
    </a>

</div>

<div class="card">

    <div class="card-body p-0">

        <table class="table table-hover mb-0 align-middle">

            <thead>

                <tr>

                    <th>Ürün</th>
                    <th>Tedarikçi</th>
                    <th>Miktar</th>
                    <th>Tarih</th>
                    <th>Açıklama</th>
                    <th width="220">İşlemler</th>

                </tr>

            </thead>

            <tbody>

                @if (Model.StokGiris.Any())
                {

                    @foreach (var item in Model.StokGiris)
                    {

                        <tr>

                            <td>

                                <strong>@item.Urun?.UrunAdi</strong>

                            </td>

                            <td>

                                @item.Tedarikci?.FirmaAdi

                            </td>

                            <td>

                                @if (item.Miktar <= 20)
                                {
                                    <span class="badge bg-danger">
                                        @item.Miktar
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-success">
                                        @item.Miktar
                                    </span>
                                }

                            </td>

                            <td>

                                @item.Tarih.ToString("dd.MM.yyyy HH:mm")

                            </td>

                            <td>

                                @item.Aciklama

                            </td>

                            <td>

                                <a asp-page="./Edit"
                                   asp-route-id="@item.StokGirisId"
                                   class="btn btn-success btn-sm">

                                    Düzenle

                                </a>

                                <a asp-page="./Details"
                                   asp-route-id="@item.StokGirisId"
                                   class="btn btn-success btn-sm">

                                    Detay

                                </a>

                                <a asp-page="./Delete"
                                   asp-route-id="@item.StokGirisId"
                                   class="btn btn-success btn-sm">

                                    Sil

                                </a>

                            </td>

                        </tr>

                    }

                }
                else
                {

                    <tr>

                        <td colspan="6" class="text-center py-4">

                            Henüz stok girişi bulunmamaktadır.

                        </td>

                    </tr>

                }

            </tbody>

        </table>

    </div>

</div>
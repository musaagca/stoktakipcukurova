<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - Çukurova Üniversitesi Yemekhane Stok Takip Sistemi</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/YemekhaneStokTakipV2.styles.css" asp-append-version="true" />
</head>

<body>

    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-success shadow-sm">
            <div class="container">

                <a class="navbar-brand d-flex align-items-center" asp-page="/Index">

                    <img src="~/images/cu-logo.png"
                         width="45"
                         height="45"
                         class="me-2" />

                    <div>
                        <strong>Çukurova Üniversitesi</strong><br />
                        <small style="font-size:12px;">
                            Yemekhane Stok Takip Sistemi
                        </small>
                    </div>

                </a>

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#navbarNav">

                    <span class="navbar-toggler-icon"></span>

                </button>

                <div class="collapse navbar-collapse" id="navbarNav">

                    <ul class="navbar-nav ms-auto">

                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Index">🏠 Ana Sayfa</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-page="/UrunPages/Index">📦 Ürünler</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-page="/KategoriPages/Index">🗂️ Kategoriler</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-page="/TedarikciPages/Index">🚚 Tedarikçiler</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-page="/StokGirisPages/Index">📥 Stok Girişi</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-page="/StokCikisPages/Index">📤 Stok Çıkışı</a>
                        </li>

                    </ul>

                </div>

            </div>
        </nav>
    </header>

    <div class="container mt-4">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="bg-success text-white text-center mt-5 p-3">
        <strong>© 2026 Çukurova Üniversitesi</strong><br />
        Bilgi İşlem Daire Başkanlığı - Yemekhane Stok Takip Sistemi
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
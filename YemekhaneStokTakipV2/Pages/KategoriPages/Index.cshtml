@page
@model YemekhaneStokTakipV2.Pages.KategoriPages.IndexModel

@{
    ViewData["Title"] = "Kategoriler";
}

<h2 class="mb-3">📂 Kategori Listesi</h2>

<div class="card shadow-sm border-success mb-3">
    <div class="card-body">
        <h5 class="mb-1">📂 Kategori Yönetimi</h5>
        <p class="mb-0">
            Toplam Kategori :
            <strong>@Model.Kategori.Count</strong>
        </p>
    </div>
</div>

@if (TempData["Basari"] != null)
{
    <div class="alert alert-success">
        @TempData["Basari"]
    </div>
}

@if (TempData["Hata"] != null)
{
    <div class="alert alert-danger">
        @TempData["Hata"]
    </div>
}

<div class="row mb-3">
    <div class="col-md-4">
        <input type="text"
               id="kategoriAra"
               class="form-control"
               placeholder="🔍 Kategori Ara...">
    </div>

    <div class="col-md-8 text-end">
        <a asp-page="Create" class="btn btn-success">
            ➕ Yeni Kategori Ekle
        </a>
    </div>
</div>

<table class="table table-bordered table-hover table-striped align-middle shadow-sm">
    <thead class="table-success">
        <tr>
            <th style="width:70px;">#</th>
            <th>Kategori Adı</th>
            <th style="width:260px;">İşlemler</th>
        </tr>
    </thead>

    <tbody>

        @if (Model.Kategori.Any())
        {
            @for (int i = 0; i < Model.Kategori.Count; i++)
            {
                <tr>
                    <td>@(i + 1)</td>

                    <td>@Model.Kategori[i].KategoriAdi</td>

                    <td>
                        <a asp-page="./Edit"
                           asp-route-id="@Model.Kategori[i].KategoriId"
                           class="btn btn-warning btn-sm">
                            ✏️ Düzenle
                        </a>

                        <a asp-page="./Details"
                           asp-route-id="@Model.Kategori[i].KategoriId"
                           class="btn btn-info btn-sm text-white">
                            👁️ Detay
                        </a>

                        <a asp-page="./Delete"
                           asp-route-id="@Model.Kategori[i].KategoriId"
                           class="btn btn-danger btn-sm">
                            🗑️ Sil
                        </a>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="3" class="text-center text-muted">
                    Henüz kategori bulunmamaktadır.
                </td>
            </tr>
        }

    </tbody>
</table>

@section Scripts
{
    <script>
        document.getElementById("kategoriAra").addEventListener("keyup", function() {

            var value = this.value.toLowerCase();

            document.querySelectorAll("tbody tr").forEach(function(row) {

                row.style.display =
                    row.innerText.toLowerCase().includes(value)
                        ? ""
                        : "none";

            });

        });
    </script>
}
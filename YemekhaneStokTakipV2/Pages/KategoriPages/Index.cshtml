@page
@model YemekhaneStokTakipV2.Pages.KategoriPages.IndexModel

@{
    ViewData["Title"] = "Kategoriler";
}

<h2 class="mb-3">📂 Kategori Listesi</h2>
@if (TempData["Basari"] != null)
{
    <div class="alert alert-success">
        @TempData["Basari"]
    </div>
}

@if (TempData["Hata"] != null)
{
    <div class="alert alert-danger">
        @TempData["Hata"]
    </div>
}
<p>
    <a asp-page="Create" class="btn btn-success">
        + Yeni Kategori Ekle
    </a>
</p>

<table class="table table-bordered table-hover table-striped align-middle">
    <thead class="table-success">
        <tr>
            <th>Kategori Adı</th>
            <th style="width:250px;">İşlemler</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model.Kategori)
        {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.KategoriAdi)
                </td>

                <td>
                    <a asp-page="./Edit"
                       asp-route-id="@item.KategoriId"
                       class="btn btn-warning btn-sm">
                        Düzenle
                    </a>

                    <a asp-page="./Details"
                       asp-route-id="@item.KategoriId"
                       class="btn btn-info btn-sm text-white">
                        Detay
                    </a>

                    <a asp-page="./Delete"
                       asp-route-id="@item.KategoriId"
                       class="btn btn-danger btn-sm">
                        Sil
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>
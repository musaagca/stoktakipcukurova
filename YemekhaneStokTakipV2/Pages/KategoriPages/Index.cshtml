@page
@model YemekhaneStokTakipV2.Pages.KategoriPages.IndexModel
@{
    ViewData["Title"] = "Kategori Yönetimi";
}
<div class="d-flex justify-content-between align-items-center mb-4"><div><h2 class="fw-bold text-success">📂 Kategori Yönetimi</h2><small>Toplam Kategori: <strong>@Model.Kategori.Count</strong></small></div><a asp-page="Create" class="btn btn-success">➕ Yeni Kategori</a></div>
@if (TempData["Basari"] != null)
{
    <div class="alert alert-success">@TempData["Basari"]</div>
}
@if (TempData["Hata"] != null)
{
    <div class="alert alert-danger">@TempData["Hata"]</div>
}
<form method="get" class="mb-3"><input asp-for="Ara" class="form-control" placeholder="🔍 Kategori ara..." /></form>
<div class="card shadow"><div class="card-body p-0"><table class="table table-hover mb-0"><thead class="table-success"><tr><th>#</th><th>Kategori Adı</th><th>İşlemler</th></tr></thead><tbody>@if(Model.Kategori.Any()){@for(int i=0;i<Model.Kategori.Count;i++){
    <tr><td>@(i + 1)</td><td><strong>@Model.Kategori[i].KategoriAdi</strong></td><td><a asp-page="./Edit" asp-route-id="@Model.Kategori[i].KategoriId" class="btn btn-warning btn-sm">Düzenle</a> <a asp-page="./Details" asp-route-id="@Model.Kategori[i].KategoriId" class="btn btn-info btn-sm text-white">Detay</a> <a asp-page="./Delete" asp-route-id="@Model.Kategori[i].KategoriId" class="btn btn-danger btn-sm">Sil</a></td></tr>
}
}else
{
    <tr><td colspan="3" class="text-center">Kategori bulunamadı.</td></tr>
}
</tbody></table></div></div>
@page
@model YemekhaneStokTakipV2.Pages.KategoriPages.IndexModel

@{
    ViewData["Title"] = "Kategori Yönetimi";
}

<div class="d-flex justify-content-between align-items-center mb-4">

    <div>

        <h2 class="fw-bold">
            Kategori Yönetimi
        </h2>

        <small class="text-muted">
            Toplam Kategori :
            <strong>@Model.Kategori.Count</strong>
        </small>

    </div>

    <a asp-page="Create" class="btn btn-success">
        Yeni Kategori
    </a>

</div>

@if (TempData["Basari"] != null)
{
    <div class="alert alert-success">
        @TempData["Basari"]
    </div>
}

@if (TempData["Hata"] != null)
{
    <div class="alert alert-danger">
        @TempData["Hata"]
    </div>
}

<form method="get" class="mb-4">

    <input asp-for="Ara"
           class="form-control"
           placeholder="Kategori ara..." />

</form>

<div class="card">

    <div class="card-body p-0">

        <table class="table table-hover mb-0">

            <thead>

                <tr>

                    <th width="80">#</th>

                    <th>Kategori Adı</th>

                    <th width="220">İşlemler</th>

                </tr>

            </thead>

            <tbody>

                @if (Model.Kategori.Any())
                {

                    @for (int i = 0; i < Model.Kategori.Count; i++)
                    {

                        <tr>

                            <td>
                                @(i + 1)
                            </td>

                            <td>

                                <strong>
                                    @Model.Kategori[i].KategoriAdi
                                </strong>

                            </td>

                            <td>

                                <a asp-page="./Edit"
                                   asp-route-id="@Model.Kategori[i].KategoriId"
                                   class="btn btn-success btn-sm">

                                    Düzenle

                                </a>

                                <a asp-page="./Details"
                                   asp-route-id="@Model.Kategori[i].KategoriId"
                                   class="btn btn-success btn-sm">

                                    Detay

                                </a>

                                <a asp-page="./Delete"
                                   asp-route-id="@Model.Kategori[i].KategoriId"
                                   class="btn btn-success btn-sm">

                                    Sil

                                </a>

                            </td>

                        </tr>

                    }

                }
                else
                {

                    <tr>

                        <td colspan="3" class="text-center py-4">

                            Kayıtlı kategori bulunamadı.

                        </td>

                    </tr>

                }

            </tbody>

        </table>

    </div>

</div>
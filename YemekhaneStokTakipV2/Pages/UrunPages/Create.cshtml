@page
@model YemekhaneStokTakipV2.Pages.UrunPages.CreateModel

@{
    ViewData["Title"] = "Yeni Ürün";
}

<h2 class="mb-3">📦 Yeni Ürün Ekle</h2>

<hr />

<div class="row">
    <div class="col-md-6">

        <form method="post">

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="Urun.UrunAdi" class="form-label"></label>
                <input asp-for="Urun.UrunAdi" class="form-control" />
                <span asp-validation-for="Urun.UrunAdi" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Urun.KategoriId" class="form-label"></label>
                <select asp-for="Urun.KategoriId"
                        class="form-select"
                        asp-items="ViewBag.KategoriId">
                    <option value="">Kategori Seçiniz</option>
                </select>
                <span asp-validation-for="Urun.KategoriId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Urun.Birim" class="form-label"></label>
                <input asp-for="Urun.Birim" class="form-control" />
                <span asp-validation-for="Urun.Birim" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Urun.MevcutStok" class="form-label"></label>
                <input asp-for="Urun.MevcutStok" class="form-control" />
                <span asp-validation-for="Urun.MevcutStok" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Urun.KritikStok" class="form-label"></label>
                <input asp-for="Urun.KritikStok" class="form-control" />
                <span asp-validation-for="Urun.KritikStok" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-success">
                💾 Kaydet
            </button>

            <a asp-page="./Index" class="btn btn-secondary">
                Geri Dön
            </a>

        </form>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
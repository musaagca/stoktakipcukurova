@page
@model YemekhaneStokTakipV2.Pages.StokCikisPages.IndexModel

@{
    ViewData["Title"] = "Stok Çıkışları";
}

<h1>📤 Stok Çıkışları</h1>

<p>
    <a asp-page="Create" class="btn btn-success">➕ Yeni Stok Çıkışı</a>
</p>

<table class="table table-bordered table-striped">
    <thead class="table-dark">
        <tr>
            <th>Ürün</th>
            <th>Miktar</th>
            <th>Tarih</th>
            <th>Açıklama</th>
            <th>İşlemler</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.StokCikis)
        {
            <tr>
                <td>@item.Urun?.UrunAdi</td>
                <td>@item.Miktar</td>
                <td>@item.Tarih.ToString("dd.MM.yyyy HH:mm")</td>
                <td>@item.Aciklama</td>
                <td>
                    <a asp-page="./Edit" asp-route-id="@item.StokCikisId" class="btn btn-warning btn-sm">
                        Düzenle
                    </a>

                    <a asp-page="./Details" asp-route-id="@item.StokCikisId" class="btn btn-info btn-sm">
                        Detay
                    </a>

                    <a asp-page="./Delete" asp-route-id="@item.StokCikisId" class="btn btn-danger btn-sm">
                        Sil
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>
@page
@model YemekhaneStokTakipV2.Pages.TedarikciPages.IndexModel

@{
    ViewData["Title"] = "Tedarikçiler";
}

<h2 class="mb-3">🏢 Tedarikçi Listesi</h2>

<p>
    <a asp-page="Create" class="btn btn-success">
        + Yeni Tedarikçi Ekle
    </a>
</p>

<table class="table table-bordered table-hover table-striped align-middle">
    <thead class="table-success">
        <tr>
            <th>Firma Adı</th>
            <th>Telefon</th>
            <th>Adres</th>
            <th style="width:250px;">İşlemler</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model.Tedarikci)
        {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.FirmaAdi)
                </td>

                <td>
                    @Html.DisplayFor(modelItem => item.Telefon)
                </td>

                <td>
                    @Html.DisplayFor(modelItem => item.Adres)
                </td>

                <td>
                    <a asp-page="./Edit"
                       asp-route-id="@item.TedarikciId"
                       class="btn btn-warning btn-sm">
                        Düzenle
                    </a>

                    <a asp-page="./Details"
                       asp-route-id="@item.TedarikciId"
                       class="btn btn-info btn-sm text-white">
                        Detay
                    </a>

                    <a asp-page="./Delete"
                       asp-route-id="@item.TedarikciId"
                       class="btn btn-danger btn-sm">
                        Sil
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>
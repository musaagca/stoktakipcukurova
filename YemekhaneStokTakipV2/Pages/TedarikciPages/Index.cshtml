@page
@model YemekhaneStokTakipV2.Pages.TedarikciPages.IndexModel

@{
    ViewData["Title"] = "Tedarikçi Yönetimi";
}

<div class="d-flex justify-content-between align-items-center mb-4">

    <div>

        <h2 class="fw-bold">
            Tedarikçi Yönetimi
        </h2>

        <small class="text-muted">
            Sistemde kayıtlı tedarikçiler
        </small>

    </div>

    <a asp-page="Create" class="btn btn-success">
        Yeni Tedarikçi Ekle
    </a>

</div>

<div class="card">

    <div class="card-body p-0">

        <table class="table table-hover mb-0 align-middle">

            <thead>

                <tr>

                    <th>Firma Adı</th>
                    <th>Telefon</th>
                    <th>Adres</th>
                    <th width="220">İşlemler</th>

                </tr>

            </thead>

            <tbody>

                @if (Model.Tedarikci.Any())
                {

                    @foreach (var item in Model.Tedarikci)
                    {

                        <tr>

                            <td>

                                <strong>
                                    @item.FirmaAdi
                                </strong>

                            </td>

                            <td>

                                @item.Telefon

                            </td>

                            <td>

                                @item.Adres

                            </td>

                            <td>

                                <a asp-page="./Edit"
                                   asp-route-id="@item.TedarikciId"
                                   class="btn btn-success btn-sm">

                                    Düzenle

                                </a>

                                <a asp-page="./Details"
                                   asp-route-id="@item.TedarikciId"
                                   class="btn btn-success btn-sm">

                                    Detay

                                </a>

                                <a asp-page="./Delete"
                                   asp-route-id="@item.TedarikciId"
                                   class="btn btn-success btn-sm">

                                    Sil

                                </a>

                            </td>

                        </tr>

                    }

                }
                else
                {

                    <tr>

                        <td colspan="4" class="text-center py-4">

                            Kayıtlı tedarikçi bulunamadı.

                        </td>

                    </tr>

                }

            </tbody>

        </table>

    </div>

</div>